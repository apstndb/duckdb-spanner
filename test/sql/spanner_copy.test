# name: test/sql/spanner_copy.test
# description: COPY TO ... FORMAT spanner
# group: [spanner]
#
# Prerequisites:
#   make emulator-start
#   bash tests/setup_sqllogic_db.sh

require spanner

require-env SPANNER_EMULATOR_HOST

statement ok
SET allow_extensions_metadata_mismatch=true;

statement ok
SET spanner_database_path = 'projects/test-project/instances/test-instance/databases/test-db';

statement ok
SET spanner_endpoint = '${SPANNER_EMULATOR_HOST}';

# --- basic COPY and read-back ---

statement ok
COPY (SELECT CAST(900 AS BIGINT) AS Id, 'sqllogic_alice' AS Name, CAST(1.5 AS DOUBLE) AS Value) TO 'CopyTarget' (FORMAT spanner);

statement ok
SELECT IF(Name = 'sqllogic_alice', 1, error('expected copied name')) FROM spanner_query('SELECT Name FROM CopyTarget WHERE Id = 900');

statement ok
SELECT IF(strpos(Value::VARCHAR, '1.5') > 0, 1, error('expected copied value 1.5')) FROM spanner_query('SELECT Value FROM CopyTarget WHERE Id = 900');

# --- typed COPY ---

statement ok
COPY (SELECT CAST(901 AS BIGINT) AS Id, true AS BoolCol, CAST(42 AS BIGINT) AS Int64Col, 3.125 AS Float64Col, 'hello' AS StringCol, DATE '2024-01-15' AS DateCol, TIMESTAMPTZ '2024-06-15T10:30:00Z' AS TimestampCol) TO 'CopyTypes' (FORMAT spanner);

statement ok
SELECT IF(BoolCol IS TRUE AND Int64Col = 42 AND StringCol = 'hello', 1, error('expected copied scalar types')) FROM spanner_query('SELECT BoolCol, Int64Col, StringCol FROM CopyTypes WHERE Id = 901');

# --- insert mode ---

statement ok
COPY (SELECT CAST(902 AS BIGINT) AS Id, 'insert_mode' AS Name, CAST(9.9 AS DOUBLE) AS Value) TO 'CopyTarget' (FORMAT spanner, mode 'insert');

statement ok
SELECT IF(Name = 'insert_mode', 1, error('expected insert_mode row')) FROM spanner_query('SELECT Name FROM CopyTarget WHERE Id = 902');

# --- explicit COPY target column order ---
# The `columns` option names the target Spanner columns in source-column order.
# It lets COPY preserve a source query whose aliases or order do not match the
# target table's writable ordinal order.

statement ok
COPY (SELECT CAST(4.25 AS DOUBLE), CAST(903 AS BIGINT), 'reordered_columns') TO 'CopyTarget' (FORMAT spanner, columns ['Value', 'Id', 'Name']);

statement ok
SELECT IF(Name = 'reordered_columns' AND strpos(Value::VARCHAR, '4.25') > 0, 1, error('expected explicit reordered COPY columns')) FROM spanner_query('SELECT Name, Value FROM CopyTarget WHERE Id = 903');

# --- generated columns are excluded from the writable target list ---
# CopyGenerated has a generated column (Doubled) sitting between the writable
# columns (Id, Amount, Label). COPY must map the 3 source columns positionally
# onto the 3 writable columns, skipping Doubled, which Spanner computes itself.

statement ok
COPY (SELECT CAST(910 AS BIGINT) AS Id, CAST(21 AS BIGINT) AS Amount, 'gen_label' AS Label) TO 'CopyGenerated' (FORMAT spanner);

statement ok
SELECT IF(Amount = 21 AND Doubled = 42 AND Label = 'gen_label', 1, error('expected generated column computed and writable columns aligned')) FROM spanner_query('SELECT Amount, Doubled, Label FROM CopyGenerated WHERE Id = 910');

# Supplying a value for the generated column (4 source columns vs 3 writable)
# must fail with a clear count-mismatch error rather than silently corrupting data.

statement error
COPY (SELECT CAST(911 AS BIGINT) AS Id, CAST(5 AS BIGINT) AS Amount, CAST(999 AS BIGINT) AS Doubled, 'x' AS Label) TO 'CopyGenerated' (FORMAT spanner);
----
Column count mismatch
