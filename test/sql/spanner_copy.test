# name: test/sql/spanner_copy.test
# description: COPY TO ... FORMAT spanner
# group: [spanner]
#
# Prerequisites:
#   make emulator-start
#   bash tests/setup_sqllogic_db.sh

require spanner

require-env SPANNER_EMULATOR_HOST

statement ok
SET allow_extensions_metadata_mismatch=true;

statement ok
SET spanner_database_path = 'projects/test-project/instances/test-instance/databases/test-db';

statement ok
SET spanner_endpoint = '${SPANNER_EMULATOR_HOST}';

# --- basic COPY and read-back ---

statement ok
COPY (SELECT CAST(900 AS BIGINT) AS Id, 'sqllogic_alice' AS Name, CAST(1.5 AS DOUBLE) AS Value) TO 'CopyTarget' (FORMAT spanner);

statement ok
SELECT IF(Name = 'sqllogic_alice', 1, error('expected copied name')) FROM spanner_query('SELECT Name FROM CopyTarget WHERE Id = 900');

statement ok
SELECT IF(strpos(Value::VARCHAR, '1.5') > 0, 1, error('expected copied value 1.5')) FROM spanner_query('SELECT Value FROM CopyTarget WHERE Id = 900');

# --- typed COPY ---

statement ok
COPY (SELECT CAST(901 AS BIGINT) AS Id, true AS BoolCol, CAST(42 AS BIGINT) AS Int64Col, 3.125 AS Float64Col, 'hello' AS StringCol, DATE '2024-01-15' AS DateCol, TIMESTAMPTZ '2024-06-15T10:30:00Z' AS TimestampCol) TO 'CopyTypes' (FORMAT spanner);

statement ok
SELECT IF(BoolCol IS TRUE AND Int64Col = 42 AND StringCol = 'hello', 1, error('expected copied scalar types')) FROM spanner_query('SELECT BoolCol, Int64Col, StringCol FROM CopyTypes WHERE Id = 901');

# --- insert mode ---

statement ok
COPY (SELECT CAST(902 AS BIGINT) AS Id, 'insert_mode' AS Name, CAST(9.9 AS DOUBLE) AS Value) TO 'CopyTarget' (FORMAT spanner, mode 'insert');

statement ok
SELECT IF(Name = 'insert_mode', 1, error('expected insert_mode row')) FROM spanner_query('SELECT Name FROM CopyTarget WHERE Id = 902');
