# name: test/sql/spanner_params.test
# description: spanner_query params round-trip via spanner_value
# group: [spanner]
#
# Prerequisites:
#   make emulator-start
#   bash tests/setup_sqllogic_db.sh

require spanner

require-env SPANNER_EMULATOR_HOST

statement ok
SET allow_extensions_metadata_mismatch=true;

statement ok
SET spanner_database_path = 'projects/test-project/instances/test-instance/databases/test-db';

statement ok
SET spanner_endpoint = '${SPANNER_EMULATOR_HOST}';

statement ok
SELECT IF(Int64Col = 42, 1, error('expected param round-trip 42')) FROM spanner_query('SELECT @v AS Int64Col', params := {'v': spanner_value(42::BIGINT)});

statement ok
SELECT IF(StringCol = 'hello', 1, error('expected param round-trip hello')) FROM spanner_query('SELECT @name AS StringCol', params := {'name': spanner_value('hello')});

statement ok
SELECT IF(count = 1, 1, error('expected one filtered row')) FROM (SELECT COUNT(*)::INT AS count FROM spanner_query('SELECT Id FROM ScalarTypes WHERE Id = @id', params := {'id': spanner_value(1::BIGINT)}));

statement ok
SELECT IF(len(Intervals) = 2, 1, error('expected ARRAY<INTERVAL> param round-trip')) FROM spanner_query('SELECT @v AS Intervals', params := {'v': spanner_typed(['P1D', 'P1Y3M'], 'ARRAY<INTERVAL>')});

# Spanner accepts component-wise negative ISO 8601 durations. Verify these
# values travel through interval_to_iso8601, spanner_typed, and spanner_query.
statement ok
SELECT IF(interval_to_iso8601(NegativeMonth) = 'P-1Y11M', 1, error('expected negative month interval round-trip')) FROM spanner_query('SELECT @v AS NegativeMonth', params := {'v': spanner_typed(INTERVAL '-1 month', 'INTERVAL')});

statement ok
SELECT IF(interval_to_iso8601(NegativeDay) = 'P-1D', 1, error('expected negative day interval round-trip')) FROM spanner_query('SELECT @v AS NegativeDay', params := {'v': spanner_typed(INTERVAL '-1 day', 'INTERVAL')});

statement ok
SELECT IF(interval_to_iso8601(NegativeMicros) = 'PT-1H59M59.999999S', 1, error('expected negative microsecond interval round-trip')) FROM spanner_query('SELECT @v AS NegativeMicros', params := {'v': spanner_typed(INTERVAL '-1 microsecond', 'INTERVAL')});

statement ok
SELECT IF(interval_to_iso8601(MixedDate) = 'P1M-1D', 1, error('expected mixed-sign date interval round-trip')) FROM spanner_query('SELECT @v AS MixedDate', params := {'v': spanner_typed(INTERVAL '1 month -1 day', 'INTERVAL')});

statement ok
SELECT IF(interval_to_iso8601(MixedTime) = 'P1DT-1H', 1, error('expected mixed-sign time interval round-trip')) FROM spanner_query('SELECT @v AS MixedTime', params := {'v': spanner_typed(INTERVAL '1 day -1 hour', 'INTERVAL')});
